#!/bin/sh
set -e

echo "🚀 Running checks before push..."

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    cmd.exe /c gradlew.bat spotlessApply check
    ;;
  *)
    chmod +x ./gradlew
    ./gradlew spotlessApply check
    ;;
esac

if ! git diff --quiet; then
  echo "❌ Spotless changed files. Please review and commit the changes before pushing."
  git status --short
  exit 1
fi

echo "✅ Pre-push checks passed."
